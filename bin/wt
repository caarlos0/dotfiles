#!/usr/bin/env fish
set -g worktree_base ~/Developer/worktrees

function log
    echo (set_color --bold magenta) "→ $argv" (set_color normal)
end

function fail
    echo (set_color --bold red) "error: $argv" (set_color normal)
    exit 1
end

function project_name
    set -l remote_url (git remote get-url origin 2>/dev/null)
    if test -n "$remote_url"
        basename $remote_url .git
    else
        basename (git rev-parse --show-toplevel)
    end
end

function ensure_repo
    git rev-parse --git-dir >/dev/null 2>&1
    or fail "not inside a git repository"
end

function list_worktrees
    set -l selected (git worktree list --porcelain | \
		grep '^worktree ' | \
		string replace 'worktree ' '' | \
		fzf --prompt "worktree> ")
    test -n "$selected"
    and echo $selected
end

function sanitize_name -a name
    string replace -a '/' '-' -- $name
end

function worktree_path -a name
    echo $worktree_base/(project_name)-(sanitize_name $name)
end

function find_worktree -a name
    set -l sanitized (sanitize_name $name)
    set -l prefixed (project_name)-$sanitized
    git worktree list --porcelain | grep '^worktree ' | string replace 'worktree ' '' | while read -l wt
        set -l base (basename $wt)
        if test "$base" = "$name" -o "$base" = "$sanitized" -o "$base" = "$prefixed"
            echo $wt
            return 0
        end
    end
    return 1
end

function switch_to -a dir
    if test -n "$WT_POST_CMD"
        echo "$dir"
    else
        log "Switching to $dir"
        cd $dir
        exec fish
    end
end

function create_worktree -a name -a base_ref
    set -l wt_path (worktree_path $name)
    if test -n "$base_ref"
        log "Creating worktree at $wt_path from $base_ref..."
        git worktree add $wt_path -b $name $base_ref
    else
        log "Creating worktree at $wt_path..."
        git worktree add $wt_path -b $name
    end
    or fail "failed to create worktree '$name'"
end

function remove_worktree -a name
    set -l wt_path (find_worktree $name)
    if test -z "$wt_path"
        fail "worktree '$name' not found"
    end
    log "Removing worktree $wt_path..."
    git worktree remove $wt_path --force
    and log "Worktree '$name' removed."
end

function is_merged -a branch -a target
    # regular merge
    git merge-base --is-ancestor $branch $target 2>/dev/null
    and return 0

    # squash merge: build a synthetic squash commit and check ancestry
    set -l mb (git merge-base $target $branch 2>/dev/null)
    or return 1
    set -l tree (git rev-parse "$branch^{tree}" 2>/dev/null)
    or return 1
    set -l sc (git commit-tree $tree -p $mb -m _ 2>/dev/null)
    or return 1
    git merge-base --is-ancestor $sc $target 2>/dev/null
end

function cleanup_worktrees
    set -l default_branch (git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | string replace 'refs/remotes/origin/' '')
    if test -z "$default_branch"
        set default_branch main
    end

    set -l current_wt (git rev-parse --show-toplevel 2>/dev/null)
    set -l main_wt (git worktree list --porcelain | head -1 | string replace 'worktree ' '')
    set -l removed 0
    set -l wt_path ""

    for line in (git worktree list --porcelain)
        if string match -q 'worktree *' $line
            set wt_path (string replace 'worktree ' '' $line)
        else if string match -q 'branch *' $line
            if test -n "$wt_path" -a "$wt_path" != "$main_wt" -a "$wt_path" != "$current_wt"
                set -l branch (string replace 'branch refs/heads/' '' $line)
                if is_merged $branch origin/$default_branch
                    log "Removing merged worktree '$branch'..."
                    git worktree remove $wt_path --force
                    and begin
                        git branch -d $branch 2>/dev/null
                        set removed (math $removed + 1)
                    end
                end
            end
            set wt_path ""
        end
    end

    git worktree prune 2>/dev/null

    if test $removed -eq 0
        log "No merged worktrees to clean up."
    else
        log "Cleaned up $removed worktree(s)."
    end
end

# ---

ensure_repo

set -l name ""
set -l delete false
set -l list false
set -l cleanup false
set -l from_main false

for arg in $argv
    switch $arg
        case --delete -d
            set delete true
        case --list -l
            set list true
        case --cleanup -c
            set cleanup true
        case --main -m
            set from_main true
        case '*'
            set name $arg
    end
end

if test "$list" = true
    set -l prefix (project_name)-
    git worktree list | while read -l line
        set -l parts (string match -r '^(\S+)\s+(\S+)' $line)
        set -l name (string replace -- $prefix '' (basename $parts[2]))
        printf "%s%s%s\t%s\t%s\n" (set_color --bold) $name (set_color normal) $parts[3] $parts[2]
    end | column -t -s \t
else if test "$delete" = true
    if test -z "$name"
        fail "usage: wt <name> --delete"
    end
    remove_worktree $name
else if test -z "$name"
    # no args: interactive picker
    set -l selected (list_worktrees)
    if test -n "$selected"
        switch_to $selected
    end
else if test "$name" = cleanup -o "$cleanup" = true
    cleanup_worktrees
else if test "$name" = -
    # switch back to main repo or previous worktree
    if set -q WT_PREVIOUS
        switch_to $WT_PREVIOUS
    else
        set -l toplevel (git rev-parse --show-toplevel 2>/dev/null)
        set -l common (git worktree list --porcelain | head -1 | string replace 'worktree ' '')
        if test "$toplevel" != "$common"
            switch_to $common
        else
            fail "already in the main repository"
        end
    end
else
    set -l existing (find_worktree $name)
    if test -n "$existing"
        log "Worktree '$name' already exists."
        switch_to $existing
    else
        if test "$from_main" = true
            create_worktree $name origin/main
        else
            create_worktree $name
        end
        and switch_to (worktree_path $name)
    end
end
