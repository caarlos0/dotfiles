#!/usr/bin/env fish
set -g worktree_base ~/Developer/worktrees

function log
    echo (set_color --bold magenta) "→ $argv" (set_color normal)
end

function fail
    echo (set_color --bold red) "error: $argv" (set_color normal)
    exit 1
end

function project_name
    set -l remote_url (git remote get-url origin 2>/dev/null)
    if test -n "$remote_url"
        basename $remote_url .git
    else
        basename (git rev-parse --show-toplevel)
    end
end

function ensure_repo
    git rev-parse --git-dir >/dev/null 2>&1
    or fail "not inside a git repository"
end

function list_worktrees
    set -l lines
    set -l wt_path ""
    for line in (git worktree list --porcelain)
        if string match -q 'worktree *' $line
            set wt_path (string replace 'worktree ' '' $line)
        else if string match -q 'branch *' $line
            set -l branch (string replace 'branch refs/heads/' '' $line)
            set -a lines "$wt_path"\t"$branch"
            set wt_path ""
        else if test "$line" = detached
            set -a lines "$wt_path"\t(basename $wt_path)" (detached)"
            set wt_path ""
        end
    end

    set -l selected (printf '%s\n' $lines | \
        fzf --prompt "worktree> " --with-nth 2 --delimiter \t | \
        string split -f1 \t)
    test -n "$selected"
    and echo $selected
end

function worktree_path -a name
    echo $worktree_base/(project_name)/$name
end

function find_worktree -a name
    set -l expected (worktree_path $name)
    set -l wt_path ""
    set -l dir_match ""

    for line in (git worktree list --porcelain)
        if string match -q 'worktree *' $line
            set wt_path (string replace 'worktree ' '' $line)
            if test "$wt_path" = "$expected"
                set dir_match $wt_path
            end
        else if string match -q 'branch *' $line
            set -l branch (string replace 'branch refs/heads/' '' $line)
            if test "$branch" = "$name"
                echo $wt_path
                return 0
            end
            set wt_path ""
        end
    end

    if test -n "$dir_match"
        echo $dir_match
        return 0
    end
    return 1
end

function switch_to -a dir
    if test -n "$WT_POST_CMD"
        echo "$dir"
    else
        log "Switching to $dir"
        cd $dir
        exec fish
    end
end

function create_worktree -a name -a base_ref
    set -l wt_path (worktree_path $name)
    if test -n "$base_ref"
        log "Creating worktree at $wt_path from $base_ref..."
        git worktree add $wt_path -b $name $base_ref
    else
        log "Creating worktree at $wt_path..."
        git worktree add $wt_path -b $name
    end
    or fail "failed to create worktree '$name'"

    set -l src_nm (git rev-parse --show-toplevel)/node_modules
    if test -d $src_nm; and not test -f (git rev-parse --show-toplevel)/pnpm-lock.yaml
        ln -s $src_nm $wt_path/node_modules
        log "Symlinked node_modules"
    end
end

function has_uncommitted -a wt_path
    set -l dirty (git -C $wt_path status --porcelain 2>/dev/null)
    test -n "$dirty"
end

function has_unpushed -a wt_path
    set -l sha (git -C $wt_path rev-parse HEAD 2>/dev/null)
    or return 1
    set -l remotes (git -C $wt_path branch -r --contains $sha 2>/dev/null)
    test -z "$remotes"
end

function remove_worktree -a name
    set -l wt_path (find_worktree $name)
    if test -z "$wt_path"
        fail "worktree '$name' not found"
    end

    set -l reasons
    has_uncommitted $wt_path; and set -a reasons "uncommitted changes"
    has_unpushed $wt_path; and set -a reasons "unpushed commits"

    if test (count $reasons) -gt 0
        log "Worktree '$name' has "(string join " and " $reasons)"."
        read -l -P "Remove anyway? [y/N] " confirm
        if not string match -qir '^y' -- $confirm
            log "Aborted."
            return 1
        end
    end

    log "Removing worktree $wt_path..."
    git worktree remove $wt_path --force
    and log "Worktree '$name' removed."
end

function is_merged -a branch -a target
    # regular merge
    git merge-base --is-ancestor $branch $target 2>/dev/null
    and return 0

    # squash merge: build a synthetic squash commit and check whether its
    # patch is already present in target (git cherry marks it with "-")
    set -l mb (git merge-base $target $branch 2>/dev/null)
    or return 1
    set -l tree (git rev-parse "$branch^{tree}" 2>/dev/null)
    or return 1
    set -l sc (git commit-tree $tree -p $mb -m _ 2>/dev/null)
    or return 1
    string match -q -- '-*' (git cherry $target $sc 2>/dev/null)
end

function cleanup_worktrees
    set -l default_branch (git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | string replace 'refs/remotes/origin/' '')
    if test -z "$default_branch"
        set default_branch main
    end

    set -l current_wt (git rev-parse --show-toplevel 2>/dev/null)
    set -l main_wt (git worktree list --porcelain | head -1 | string replace 'worktree ' '')

    set -l clean_lines
    set -l other_lines
    set -l wt_path ""
    for line in (git worktree list --porcelain)
        if string match -q 'worktree *' $line
            set wt_path (string replace 'worktree ' '' $line)
        else if string match -q 'branch *' $line
            set -l branch (string replace 'branch refs/heads/' '' $line)
            if test -n "$wt_path" -a "$wt_path" != "$main_wt" -a "$wt_path" != "$current_wt"
                set -l markers
                if not is_merged $branch origin/$default_branch
                    set -a markers "not merged"
                    has_unpushed $wt_path; and set -a markers "unpushed commits"
                end
                has_uncommitted $wt_path; and set -a markers "uncommitted changes"
                if test (count $markers) -eq 0
                    set -a clean_lines "$branch"\t"$wt_path"\t"$branch "(set_color green)"[merged]"(set_color normal)
                else
                    set -a other_lines "$branch"\t"$wt_path"\t"$branch "(set_color red)"["(string join "] [" $markers)"]"(set_color normal)
                end
            end
            set wt_path ""
        else if test "$line" = detached
            set wt_path ""
        end
    end

    set -l all_lines $clean_lines $other_lines
    if test (count $all_lines) -eq 0
        log "No worktrees to clean up."
        return 0
    end

    set -l fzf_args --multi --sync --ansi --with-nth 3 --delimiter \t \
        --prompt "cleanup> " \
        --header "tab: toggle  enter: remove selected  esc: cancel"

    set -l n (count $clean_lines)
    if test $n -gt 0
        set -l bind ""
        for i in (seq 1 $n)
            set bind "$bind+pos($i)+select"
        end
        set bind (string sub -s 2 "$bind")
        set -a fzf_args --bind "load:$bind+pos(1)"
    end

    set -l selected (printf '%s\n' $all_lines | fzf $fzf_args)
    if test -z "$selected"
        log "Nothing selected."
        return 0
    end

    set -l removed 0
    for sel in $selected
        set -l branch (string split -f1 \t -- $sel)
        set -l path (string split -f2 \t -- $sel)
        log "Removing worktree '$branch'..."
        if git worktree remove $path --force
            git branch -D $branch 2>/dev/null
            set removed (math $removed + 1)
        end
    end
    git worktree prune 2>/dev/null
    log "Removed $removed worktree(s)."
end

# ---

ensure_repo

set -l name ""
set -l delete false
set -l list false
set -l cleanup false
set -l from_main false

for arg in $argv
    switch $arg
        case --delete -d
            set delete true
        case --list -l
            set list true
        case --cleanup -c
            set cleanup true
        case --main -m
            set from_main true
        case '*'
            set name $arg
    end
end

if test "$list" = true
    set -l main_wt (git worktree list --porcelain | head -1 | string replace 'worktree ' '')
    set -l wt_path ""
    for line in (git worktree list --porcelain)
        if string match -q 'worktree *' $line
            set wt_path (string replace 'worktree ' '' $line)
        else if string match -q 'branch *' $line
            if test "$wt_path" != "$main_wt"
                set -l branch (string replace 'branch refs/heads/' '' $line)
                printf "%s%s%s\n" (set_color --bold) $branch (set_color normal)
            end
            set wt_path ""
        else if test "$line" = detached
            if test "$wt_path" != "$main_wt"
                printf "%s%s%s\n" (set_color --bold) "(detached)" (set_color normal)
            end
            set wt_path ""
        end
    end
else if test "$delete" = true
    if test -z "$name"
        fail "usage: wt <name> --delete"
    end
    remove_worktree $name
else if test "$cleanup" = true -o "$name" = cleanup
    cleanup_worktrees
else if test -z "$name"
    # no args: interactive picker
    set -l selected (list_worktrees)
    if test -n "$selected"
        switch_to $selected
    end
else if test "$name" = -
    # switch back to main repo or previous worktree
    if set -q WT_PREVIOUS
        switch_to $WT_PREVIOUS
    else
        set -l toplevel (git rev-parse --show-toplevel 2>/dev/null)
        set -l common (git worktree list --porcelain | head -1 | string replace 'worktree ' '')
        if test "$toplevel" != "$common"
            switch_to $common
        else
            fail "already in the main repository"
        end
    end
else
    set -l existing (find_worktree $name)
    if test -n "$existing"
        log "Worktree '$name' already exists."
        switch_to $existing
    else
        if test "$from_main" = true
            create_worktree $name origin/main
        else
            create_worktree $name
        end
        and switch_to (worktree_path $name)
    end
end
