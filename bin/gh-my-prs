#!/bin/sh
# print my open PRs in the repo in the CWD with merge queue and check status.
set -e

repo="$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || gh repo set-default --view)"
me="$(gh api user -q .login)"
q="repo:$repo is:pr is:open author:$me archived:false"

rows="$(gh api graphql -f q="$q" -f query='
query($q: String!) {
  search(type: ISSUE, first: 50, query: $q) {
    nodes {
      ... on PullRequest {
        number title url mergeable mergeStateStatus isDraft
        mergeQueueEntry { position state }
        commits(last: 1) { nodes { commit { checkSuites(first: 50) { nodes {
          conclusion
        } } } } }
      }
    }
  }
}' -q '
def merge_glyph:
  if . == "MERGEABLE" then "✓"
  elif . == "CONFLICTING" then "✗"
  else "?" end;
.data.search.nodes
| sort_by(-(.number))
| .[]
| [
    (if .isDraft then "draft" else "#\(.number)" end),
    .title,
    (.mergeable | merge_glyph),
    (.mergeStateStatus // "?"),
    (if .mergeQueueEntry then "#\(.mergeQueueEntry.position) \(.mergeQueueEntry.state)" else "-" end),
    ([.commits.nodes[0].commit.checkSuites.nodes[]
      | select(.conclusion=="FAILURE" or .conclusion=="STARTUP_FAILURE" or .conclusion=="CANCELLED")
     ] | length | if . == 0 then "-" else tostring end),
    .url
  ]
| @tsv
')"

if [ -z "$rows" ]; then
  echo "No open PRs by $me in $repo."
  exit 0
fi

ansi=0
[ -t 1 ] && ansi=1

{
  printf 'PR\tTITLE\tMERGE\tSTATE\tQUEUE\tFAIL\tURL\n'
  printf '%s\n' "$rows"
} | awk -v ansi="$ansi" '
BEGIN { FS = "\t" }
{
  for (i=1; i<=NF; i++) {
    cell[NR, i] = $i
    L = vlen($i)
    if (L > w[i]) w[i] = L
  }
  if (NF > maxc) maxc = NF
}
END {
  for (r=1; r<=NR; r++) {
    line = ""
    for (i=1; i<=maxc; i++) {
      v = cell[r, i]
      pad = w[i] - vlen(v)
      colored = (r == 1) ? bold(v) : color(i, v)
      line = line colored sprintf("%*s", pad, "")
      if (i < maxc) line = line "  "
    }
    print line
  }
}
function vlen(s,    tmp, c) {
  tmp = s
  c = gsub(/✓|✗/, "x", tmp)
  return length(s) - 2 * c
}
function bold(s) {
  return ansi ? "\033[1m" s "\033[0m" : s
}
function paint(code, s) {
  return (ansi && code != "") ? "\033[" code "m" s "\033[0m" : s
}
function link(url, s) {
  return ansi ? "\033]8;;" url "\033\\" s "\033]8;;\033\\" : s
}
function color(i, v,    code) {
  code = ""
  if (i == 1) code = (v == "draft") ? "2" : "36"
  else if (i == 3) {
    if (v == "✓") code = "32"
    else if (v == "✗") code = "31"
    else code = "33"
  } else if (i == 4) {
    if (v == "CLEAN" || v == "HAS_HOOKS") code = "32"
    else if (v == "BLOCKED" || v == "BEHIND") code = "33"
    else if (v == "DIRTY" || v == "DRAFT") code = "31"
    else code = "2"
  } else if (i == 5) {
    if (v ~ /^#/) code = "1;33"
    else code = "2"
  } else if (i == 6) {
    if (v == "-") code = "2"
    else code = "1;31"
  } else if (i == 7) return link(v, paint("2;4", v))
  return paint(code, v)
}
'
