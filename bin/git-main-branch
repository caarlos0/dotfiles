#!/usr/bin/env fish

function resolve
    git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null |
        string replace origin/ ''
end

set branch (resolve)
if test -z "$branch"
    # origin/HEAD isn't set yet (e.g. a fresh clone); ask the remote, then retry.
    git remote set-head origin --auto >/dev/null 2>&1
    set branch (resolve)
end

if test -z "$branch"
    set branch main
end

echo $branch
