#!/usr/bin/env bash
#
# gomod-rename example.com/old/module example.com/new-module
#
go mod edit -module "${2}"
find . -type f -name '*.go' -not -path './vendor/*' -exec perl -i -pe "s,\"${1}/,\"${2}/,g" {} +
find . -type f -name '*.go' -not -path './vendor/*' -exec perl -i -pe "s,\"${1}\",\"${2}\",g" {} +
