#!/bin/sh
# print the merge queue for the repo in the CWD, highlighting your own PRs.
set -e

# force-pass the repo because --repo/auto-detection misbehaves inside worktrees.
# see: https://github.com/cli/cli/issues/1837
repo="$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || gh repo set-default --view)"
owner="${repo%/*}"
name="${repo#*/}"
me="$(gh api user -q .login)"

rows="$(gh api graphql -f owner="$owner" -f name="$name" -f query='
query($owner: String!, $name: String!) {
  repository(owner: $owner, name: $name) {
    mergeQueue {
      entries(first: 100) {
        nodes {
          position
          pullRequest { number title url author { login } }
        }
      }
    }
  }
}' -q '(.data.repository.mergeQueue.entries.nodes // [])[]
  | [
      (.position | tostring),
      "#\(.pullRequest.number)",
      .pullRequest.author.login,
      .pullRequest.title,
      .pullRequest.url
    ]
  | @tsv')"

if [ -z "$rows" ]; then
  echo "No merge queue (or it is empty) for $repo."
  exit 0
fi

ansi=0
[ -t 1 ] && ansi=1

{
  printf '#\tPR\tAUTHOR\tTITLE\tURL\n'
  printf '%s\n' "$rows"
} | awk -v ansi="$ansi" -v me="$me" '
BEGIN { FS = "\t" }
{
  for (i=1; i<=NF; i++) {
    cell[NR, i] = $i
    L = length($i)
    if (L > w[i]) w[i] = L
  }
  if (NF > maxc) maxc = NF
}
END {
  for (r=1; r<=NR; r++) {
    mine = (r > 1 && cell[r, 3] == me)
    line = ""
    for (i=1; i<=maxc; i++) {
      v = cell[r, i]
      pad = w[i] - length(v)
      colored = (r == 1) ? bold(v) : color(i, v, mine)
      line = line colored sprintf("%*s", pad, "")
      if (i < maxc) line = line "  "
    }
    print line
  }
}
function bold(s) {
  return ansi ? "\033[1m" s "\033[0m" : s
}
function paint(code, s) {
  return (ansi && code != "") ? "\033[" code "m" s "\033[0m" : s
}
function link(url, s) {
  return ansi ? "\033]8;;" url "\033\\" s "\033]8;;\033\\" : s
}
function color(i, v, mine,    code) {
  code = ""
  if (i == 1) code = mine ? "1;33" : "2"            # order
  else if (i == 2) code = mine ? "1;33" : "36"      # PR number
  else if (i == 3) code = mine ? "1;33" : ""        # author
  else if (i == 4) code = mine ? "1" : ""           # title
  else if (i == 5) return link(v, paint("2;4", v))  # url (clickable)
  return paint(code, v)
}
'
